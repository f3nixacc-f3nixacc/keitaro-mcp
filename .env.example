# Keitaro MCP Server Configuration
# Copy this file to .env and fill in your values

# === Single Instance (simplest setup) ===
KEITARO_URL=https://your-tracker.example.com
KEITARO_API_KEY=your-api-key-here

# Optional: custom instance name (default: "default")
# KEITARO_INSTANCE_NAME=production

# Optional: description for this instance
# KEITARO_DESCRIPTION=Production Keitaro Tracker

# === Write Protection (IMPORTANT) ===
# By default, ALL write operations (create, update, delete, clone, toggle)
# are DISABLED. Only read/analytics tools work.
# Set to "true" to enable write operations:
# KEITARO_ALLOW_WRITE=true

# === Multiple Instances (alternative to above) ===
# Point to a JSON config file instead of env vars:
# KEITARO_CONFIG_FILE=/path/to/keitaro-instances.json
#
# JSON format — see keitaro-instances.example.json
